<ManualEntryScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1  # White background
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: "20dp"
        spacing: "10dp"

        # -- Logo Area Placeholder --
        Widget:
            size_hint_y: 0.20

        # --- DISPLAY AREA ---
        BoxLayout:
            size_hint_y: 0.2
            padding: "40dp", "5dp"
            
            TextInput:
                id: ucid_input
                hint_text: "Enter UCID Number"
                text: ""
                font_size: "44sp"
                halign: "center"
                valign: "center"
                readonly: True
                multiline: False
                input_filter: 'int'
                on_text: self.text = self.text[:8]
                on_text_validate: root.submit_ucid()
                background_color: 1,1,1,1
                foreground_color: 0,0,0,1
                cursor_color: 0,0,0,1
                size_hint_y: None
                height: dp(62)

        # --- NUMBER PAD GRID ---
        GridLayout:
            cols: 3
            spacing: "10dp"
            padding: "40dp", "30dp"
            size_hint_y: 0.7
            pos_hint: {"center_x": .5}
            row_force_default: True
            row_default_height: 100

            # Row 1
            NumpadButton:
                text: "1"
                on_release: root.add_digit("1")

            NumpadButton:
                text: "2"
                on_release: root.add_digit("2")
            NumpadButton:
                text: "3"
                on_release: root.add_digit("3")

            # Row 2
            NumpadButton:
                text: "4"
                on_release: root.add_digit("4")
            NumpadButton:
                text: "5"
                on_release: root.add_digit("5")
            NumpadButton:
                text: "6"
                on_release: root.add_digit("6")

            # Row 3
            NumpadButton:
                text: "7"
                on_release: root.add_digit("7")
            NumpadButton:
                text: "8"
                on_release: root.add_digit("8")
            NumpadButton:
                text: "9"
                on_release: root.add_digit("9")

            # Row 4
            NumpadButton:
                text: "CLR"
                font_size: "28sp"
                on_press: root.clear_input()

            NumpadButton:
                text: "0"
                on_press: root.add_digit("0")

            NumpadButton:
                text: "DEL"
                font_size: "28sp"
                on_press: root.delete_last()

        # --- CONTROL BUTTONS ---
        BoxLayout:
            orientation: 'horizontal'
            spacing: "15dp"
            padding: "60dp", "15dp", "60dp", "30dp"
            size_hint_y: 0.18
            pos_hint: {"center_x": .5}

            AppButton:
                text: "CANCEL"
                font_size: "28sp"
                base_color: 0.9, 0.2, 0.2, 1  # Red
                down_color: 0.75, 0.15, 0.15, 1
                color: 1,1,1,1
                on_press: root.cancel_transaction()

            AppButton:
                text: "ENTER"
                font_size: "28sp"
                # background_normal: ''
                base_color: 0.2, 0.8, 0.2, 1  # Green
                down_color: 0.15, 0.65, 0.15, 1
                color: 1,1,1,1
                on_press: root.submit_ucid()

        # -- Spacer --
        Widget:
            size_hint_y: 0.2

# --- Custom Button Component ---
# This prevents code duplication for the number keys
<NumpadButton@AppButton>:
    font_size: "36sp"
    size_hint: .5, 1
    color: 0, 0, 0, 1         # Black Text
    width: dp(60)
    height: dp(120)