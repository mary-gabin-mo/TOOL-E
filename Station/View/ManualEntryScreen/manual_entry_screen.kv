<ManualEntryScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1  # White background
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: "20dp"
        spacing: "10dp"

        # -- Logo Area Placeholder --
        Widget:
            size_hint_y: 0.40

        # --- HEADER (Back Button + Title) ---
        BoxLayout:
            size_hint_y: 0.1
            spacing: "20dp"
            
            Button:
                background_normal: ''
                background_color: 0,0,0,0
                text: '<'  # simple back arrow
                font_size: '48sp'
                color: 0,0,0,1
                size_hint_x: None
                width: dp(80)
                on_release: root.cancel_transaction()

            # Label:
            #     text: "Enter UCID Manually"
            #     font_size: "24sp"
            #     bold: True
            #     color: 0,0,0,1
            #     halign: 'center'
            #     valign: 'middle'
            #     text_size: self.size

        # --- DISPLAY AREA ---
        BoxLayout:
            size_hint_y: 0.2
            padding: "40dp", "0dp"
            
            TextInput:
                id: ucid_input
                hint_text: "Enter UCID Number"
                text: ""
                font_size: "60sp"
                halign: "center"
                readonly: True  # Vital: Prevents OS keyboard from popping up
                background_color: 1,1,1,1
                foreground_color: 0,0,0,1
                cursor_color: 0,0,0,1
                size_hint_y: None
                height: self.font_size * 2

        # --- NUMBER PAD GRID ---
        GridLayout:
            cols: 3
            spacing: "8dp"
            padding: "80dp", "30dp"
            size_hint_y: 0.55
            pos_hint: {"center_x": .5}
            row_force_default: True
            row_default_height: 100

            # Row 1
            NumpadButton:
                text: "1"
                on_release: root.add_digit("1")
            NumpadButton:
                text: "2"
                on_release: root.add_digit("2")
            NumpadButton:
                text: "3"
                on_release: root.add_digit("3")

            # Row 2
            NumpadButton:
                text: "4"
                on_release: root.add_digit("4")
            NumpadButton:
                text: "5"
                on_release: root.add_digit("5")
            NumpadButton:
                text: "6"
                on_release: root.add_digit("6")

            # Row 3
            NumpadButton:
                text: "7"
                on_release: root.add_digit("7")
            NumpadButton:
                text: "8"
                on_release: root.add_digit("8")
            NumpadButton:
                text: "9"
                on_release: root.add_digit("9")

            # Row 4
            NumpadButton:
                text: "CLR"
                font_size: "28sp"
                on_release: root.clear_input()

            NumpadButton:
                text: "0"
                on_release: root.add_digit("0")

            NumpadButton:
                text: "DEL"
                font_size: "28sp"
                on_release: root.delete_last()

        # --- CONTROL BUTTONS ---
        BoxLayout:
            orientation: 'horizontal'
            spacing: "15dp"
            padding: "60dp", "15dp", "60dp", "30dp"
            size_hint_y: 0.18
            pos_hint: {"center_x": .5}

            Button:
                text: "CANCEL"
                font_size: "28sp"
                background_normal: ''
                background_color: 0.9, 0.2, 0.2, 1  # Red
                color: 1,1,1,1
                on_release: root.cancel_transaction()

            Button:
                text: "ENTER"
                font_size: "28sp"
                background_normal: ''
                background_color: 0.2, 0.8, 0.2, 1  # Green
                color: 1,1,1,1
                on_release: root.submit_ucid()

        Widget:
            size_hint_y: None
            height: "44dp"

# --- Custom Button Component ---
# This prevents code duplication for the number keys
<NumpadButton@Button>:
    font_size: "36sp"
    size_hint: 1, 1
    background_normal: ''
    background_color: 0.82, 0.82, 0.82, 1  # Light Grey
    color: 0, 0, 0, 1         # Black Text
    # no radius or ripple to keep it simple