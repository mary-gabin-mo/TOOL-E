<ReturnConfirmationScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1  # White background
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: "50dp"
        spacing: "40dp"
        pos_hint: {"center_x": .5, "center_y": .5}

        # --- Logo Area Placeholder ---
        Widget:
            size_hint_y: 0.3

        # --- Success Checkmark ---
        Label:
            text: "✓"
            halign: "center"
            theme_text_color: "Custom"
            text_color: 0.2, 0.8, 0.2, 1  # Green
            font_size: "120sp"
            size_hint_y: None
            height: "140dp"

        # --- Title ---
        Label:
            text: "Return Confirmed!"
            halign: "center"
            font_size: "36sp"
            bold: True
            color: 0, 0, 0, 1
            size_hint_y: None
            height: "80dp"

        # --- Message Display ---
        Label:
            id: message_display
            text: "Return confirmed!"
            halign: "center"
            font_size: "20sp"
            color: 0.5, 0.5, 0.5, 1
            size_hint_y: None
            height: "100dp"

        # --- Spacer ---
        Widget:
            size_hint_y: 0.3

        # --- Continue Button (Keep User Logged In) ---
        AppButton:
            text: "RETURN TO SELECTION"
            font_size: "32sp"
            size_hint: 0.8, None
            height: "100dp"
            pos_hint: {"center_x": .5}
            base_color: 0.2, 0.6, 0.8, 1  # Blue
            color: 1, 1, 1, 1
            on_release: root.continue_with_user()

        # --- Return Button ---
        AppButton:
            text: "RETURN TO START"
            font_size: "32sp"
            size_hint: 0.8, None
            height: "100dp"
            pos_hint: {"center_x": .5}
            base_color: 0.9, 0.17, 0.25, 1  # Red
            color: 1, 1, 1, 1
            on_release: root.return_to_menu()

        # --- Spacer ---
        Widget:
            size_hint_y: None
            height: "44dp"
