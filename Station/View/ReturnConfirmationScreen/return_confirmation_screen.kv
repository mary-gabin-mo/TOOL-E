<ReturnConfirmationScreen>:
    md_bg_color: 1, 1, 1, 1  # White background

    MDBoxLayout:
        orientation: 'vertical'
        padding: "50dp"
        spacing: "40dp"
        pos_hint: {"center_x": .5, "center_y": .5}

        # --- Logo Area Placeholder ---
        Widget:
            size_hint_y: 0.3

        # --- Success Icon/Checkmark Area ---
        MDIcon:
            icon: "check-circle"
            halign: "center"
            theme_text_color: "Custom"
            text_color: 0.2, 0.8, 0.2, 1  # Green
            font_size: "120sp"
            size_hint_y: None
            height: "140dp"

        # --- Title ---
        MDLabel:
            text: "Return Confirmed!"
            halign: "center"
            font_style: "H2"
            bold: True
            theme_text_color: "Primary"
            size_hint_y: None
            height: "80dp"

        # --- Message Display ---
        MDLabel:
            id: message_display
            text: "Return confirmed!"
            halign: "center"
            font_style: "H5"
            theme_text_color: "Secondary"
            size_hint_y: None
            height: "100dp"

        # --- Spacer ---
        Widget:
            size_hint_y: 0.3

        # --- Continue Button (Keep User Logged In) ---
        MDFillRoundFlatButton:
            text: "RETURN TO SELECTION"
            font_size: "28sp"
            size_hint: 0.8, None
            height: "100dp"
            pos_hint: {"center_x": .5}
            md_bg_color: 0.2, 0.6, 0.8, 1  # Blue
            on_release: root.continue_with_user()

        # --- Return Button ---
        MDFillRoundFlatButton:
            text: "RETURN TO START"
            font_size: "28sp"
            size_hint: 0.8, None
            height: "100dp"
            pos_hint: {"center_x": .5}
            md_bg_color: 0.9, 0.17, 0.25, 1  # Red
            on_release: root.return_to_menu()

        # --- Cancel Button ---
        MDFillRoundFlatButton:
            text: "CANCEL"
            font_size: "24sp"
            size_hint: 0.8, None
            height: "80dp"
            pos_hint: {"center_x": .5}
            md_bg_color: 0.6, 0.6, 0.6, 1  # Grey
            on_release: root.cancel_transaction()

        # --- Spacer ---
        Widget:
            size_hint_y: 0.1
