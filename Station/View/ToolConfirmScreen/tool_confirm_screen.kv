<ToolConfirmScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: "30dp"
        spacing: "14dp"
        pos_hint: {"center_x": .5, "center_y": .5}

        # -- Logo Area Placeholder --
        Widget:
            size_hint_y: 0.14

        # -- Header --
        Label:
            text: "Confirm Tool"
            halign: "center"
            valign: "middle"
            text_size: self.size
            font_size: "44sp"
            bold: True
            color: 0, 0, 0, 1
            size_hint_y: None
            height: "72dp"

        # -- Content Card --
        BoxLayout:
            orientation: "vertical"
            padding: "15dp"
            spacing: "12dp"
            size_hint: 0.96, 0.68
            pos_hint: {"center_x": .5}
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [20, 20, 20, 20]

            # 1. Captured Image
            Image:
                id: tool_image
                source: "assets/images/logo_white.png"
                allow_stretch: True
                keep_ratio: True
                size_hint_y: 0.74
                canvas.before:
                    PushMatrix
                    Rotate:
                        angle: 180
                        origin: self.center
                canvas.after:
                    PopMatrix

            # 2. Prediction Info
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: "170dp"
                spacing: "10dp"

                Label:
                    text: "Is this correct?"
                    halign: "center"
                    valign: "middle"
                    text_size: self.size
                    font_size: "22sp"
                    color: 0.5, 0.5, 0.5, 1
                    size_hint_y: None
                    height: "36dp"

                Label:
                    id: tool_name_label
                    text: "Loading..."
                    halign: "center"
                    valign: "middle"
                    text_size: self.size
                    font_size: "50sp"
                    bold: True
                    color: 0, 0, 0, 1
                    size_hint_y: None
                    height: "72dp"

                Label:
                    id: confidence_label
                    text: "--%"
                    halign: "center"
                    valign: "middle"
                    text_size: self.size
                    font_size: "28sp"
                    color: 0.2, 0.7, 0.2, 1  # Green
                    size_hint_y: None
                    height: "40dp"

        Widget:
            size_hint_y: None
            height: "44dp"

        # -- Action Buttons --
        BoxLayout:
            orientation: 'horizontal'
            spacing: "15dp"
            size_hint_x: 0.95
            size_hint_y: None
            height: "168dp"
            pos_hint: {"center_x": .5}
            padding: "8dp"

            # NO Button (Left Side)
            AppButton:
                text: "NO"
                font_size: "30sp"
                size_hint_x: 0.3
                size_hint_y: 1
                background_normal: ''
                base_color: 0.8, 0.2, 0.2, 1  # Red
                down_color: 0.65, 0.15, 0.15, 1
                color: 1, 1, 1, 1
                on_release: root.reject_tool()

            # YES Actions (Right Side - Stacked)
            BoxLayout:
                orientation: 'vertical'
                spacing: "15dp"
                size_hint_x: 0.7

                # Option 1: Scan More
                AppButton:
                    text: "YES, SCAN MORE"
                    font_size: "26sp"
                    size_hint: 1, 0.5
                    background_normal: ''
                    base_color: 0.2, 0.6, 0.8, 1  # Blue
                    down_color: 0.15, 0.65, 0.15, 1
                    color: 1, 1, 1, 1
                    on_release: root.confirm_scan_more()

                # Option 2: Finish
                AppButton:
                    text: "YES, FINISH"
                    font_size: "26sp"
                    size_hint: 1, 0.5
                    background_normal: ''
                    base_color: 0.2, 0.7, 0.2, 1  # Green
                    down_color: 0.15, 0.65, 0.15, 1
                    color: 1, 1, 1, 1
                    on_release: root.confirm_finish()

        Widget:
            size_hint_y: None
            height: "8dp"

        # -- Back Button --
        AppButton:
            text: "BACK"
            font_size: "30sp"
            size_hint_x: 0.95
            size_hint_y: None
            height: "72dp"
            pos_hint: {"center_x": .5}
            background_normal: ''
            # base_color: 0.6, 0.6, 0.6, 1  # Grey
            # down_color: 0.5, 0.5, 0.5, 1
            # color: 1, 1, 1, 1
            on_release: root.go_back_to_capture()

        Widget:
            size_hint_y: None
            height: "84dp"