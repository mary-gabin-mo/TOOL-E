<SelectableToolItem>:
    orientation: 'vertical'
    size_hint_y: None
    height: root.row_height
    padding: '14dp', '10dp'
    spacing: '6dp'
    on_release: self.handle_selection()
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size

    Label:
        text: root.text
        color: 0, 0, 0, 1
        halign: 'left'
        valign: 'middle'
        font_size: '22sp'
        text_size: self.size

    Label:
        text: root.secondary_text
        color: 0.5, 0.5, 0.5, 1
        halign: 'left'
        valign: 'middle'
        font_size: '16sp'
        text_size: self.size

    BoxLayout:
        size_hint_y: None
        height: root.preview_height
        opacity: 1 if root.preview_height > 0 else 0
        padding: '0dp', '6dp', '0dp', '0dp'

        Image:
            source: root.preview_source
            allow_stretch: True
            keep_ratio: True

<ToolSelectionScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1  # White background
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: "26dp"
        spacing: "20dp"
        pos_hint: {"center_x": .5, "center_y": .5}

        # -- Logo Area Placeholder --
        Widget:
            size_hint_y: 0.06

        Label:
            text: "Please select the correct tool:"
            halign: "center"
            font_size: "30sp"
            color: 0, 0, 0, 1
            size_hint_y: 0.1

        BoxLayout:
            orientation: 'vertical'
            padding: '5dp'
            size_hint: .96, .78
            pos_hint: {"center_x": .5}
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10, 10, 10, 10]
                Color:
                    rgba: 0.4, 0.4, 0.4, 1  # Grey border
                Line:
                    rounded_rectangle: (self.x, self.y, self.width, self.height, 10, 10, 10, 10, 100)
                    width: 1.5

            RecycleView:
                id: tool_recycle_view
                viewclass: 'SelectableToolItem'
                RecycleBoxLayout:
                    default_size: None, None
                    default_size_hint: 1, None
                    size_hint_y: None
                    height: self.minimum_height
                    orientation: 'vertical'

        BoxLayout:
            orientation: 'horizontal'
            spacing: "25dp"             # Gap between buttons
            size_hint_y: None           # Don't expand vertically
            height: '120dp'              # Fixed height for this row
            pos_hint: {"center_x": .5}
            padding: '15dp'             # Optional padding around the row

            AppButton:
                text: "Back"
                font_size: "28sp"
                size_hint: 0.5, 1
                background_normal: ''
                base_color: 0.7, 0.7, 0.7, 1  # Grey
                down_color: 0.6, 0.6, 0.6, 1
                color: 1, 1, 1, 1
                on_release: root.go_back('tool confirm screen')

            AppButton:
                text: "Scan More"
                font_size: "24sp"
                size_hint: 0.4, 1
                background_normal: ''
                base_color: 0.7, 0.7, 0.7, 1  # Grey
                down_color: 0.6, 0.6, 0.6, 1
                color: 1, 1, 1, 1
                on_release: root.confirm_scan_more()

            AppButton:
                id: next_button
                text: "Use This Tool"
                font_size: "28sp"
                size_hint: 0.5, 1
                background_normal: ''
                base_color: 0.2, 0.7, 0.2, 1  # Green
                down_color: 0.15, 0.6, 0.15, 1
                color: 1, 1, 1, 1
                disabled: True
                on_release: root.proceed()

        # -- Cancel AppButton --
        AppButton:
            text: "CANCEL"
            font_size: "30sp"
            size_hint: 1, 0.1
            pos_hint: {"center_x": .5}
            background_normal: ''
            base_color: 0.9, 0.17, 0.25, 1  # Red
            down_color: 0.8, 0.1, 0.15, 1
            color: 1, 1, 1, 1
            on_release: root.cancel_transaction()

        Widget:
            size_hint_y: None
            height: "84dp"