<CaptureScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1  # White background
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: "50dp"
        spacing: "15dp"

        # -- Logo Area Placeholder --
        Widget:
            size_hint_y: 0.15

        BoxLayout:
            orientation: 'vertical'
            padding: "20dp"
            spacing: "20dp"
            size_hint_y: 0.25

            # -- Logo Area Placeholder --
            Widget:
                size_hint_y: 0.2

            Label:
                text: "Place tool on Bed"
                halign: "center"
                font_size: "36sp"
                bold: True
                color: 0, 0, 0, 1
                size_hint_y: 0.1

        # --- CAMERA CONTAINER ---
        RelativeLayout:
            size_hint_y: 0.5

            # 1. The Camera Feed
            Image:
                id: camera_preview
                source: "assets/images/logo_white.png"
                allow_stretch: True
                keep_ratio: True
                opacity: 0

            # 2. Processing Overlay (Spinner + Text)
            BoxLayout:
                id: processing_overlay
                orientation: 'vertical'
                size_hint: None, None
                size: '180dp', '80dp'
                pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                spacing: "15dp"

                # Hidden by default (opacity 0)
                opacity: 0

                Label:
                    id: loading_spinner
                    text: "..."
                    font_size: "40sp"
                    halign: "center"
                    color: 0.2, 0.6, 0.8, 1

                Label:
                    id: loading_label
                    text: "Initializing..."
                    halign: "center"
                    font_size: "24sp"
                    bold: True
                    color: 0.2, 0.6, 0.8, 1

        BoxLayout:
            orientation: 'horizontal'
            spacing: "25dp"             # Gap between buttons
            size_hint_y: None           # Don't expand vertically
            height: '100dp'              # Fixed height for this row
            pos_hint: {"centre_x": .5}
            padding: '20dp'             # Optional padding around the row

            AppButton:
                text: "DEV - BACK\n(Action Selection\nScreen)"
                font_size: "16sp"
                size_hint: .2, 1        
                background_color: 0.4, 0.4, 0.4, 1  # Grey
                on_release: root.go_back('action selection screen')

            AppButton:
                text: "DEV - Capture"
                font_size: "16sp"
                size_hint: .2, 1        
                background_color: 0.4, 0.4, 0.4, 1  # Grey
                on_release: root.capture_btn()

            # -- DEV BUTTON --
            AppButton:
                text: "DEV - NEXT\n(Tool Confirm\nScreen)"
                font_size: "16sp"
                size_hint: .2, 1        
                background_color: 0.4, 0.4, 0.4, 1  # Grey
                on_release: root.go_to('tool confirm screen')

        # -- Spacer for the footer--
        Widget:
            size_hint_y: None
            height: "44dp"

        # -- Cancel Button --
        AppButton:
            text: "Cancel"
            font_size: "32sp"
            size_hint: 1, 0.12
            pos_hint: {"center_x": .5}
            background_color: 0.9, 0.17, 0.25, 1  # Red
            on_release: root.cancel_transaction()

        # -- Spacer for the footer--
        Widget:
            size_hint_y: 0.1