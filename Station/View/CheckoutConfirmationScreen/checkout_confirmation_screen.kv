<CheckoutConfirmationScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1  # White background
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: "40dp"
        spacing: "30dp"
        pos_hint: {"center_x": .5, "center_y": .5}

        # --- Logo Area Placeholder ---
        Widget:
            size_hint_y: 0.4

        # --- Title ---
        Label:
            text: "Checkout Confirmed!"
            halign: "center"
            font_size: "36sp"
            bold: True
            color: 0, 0, 0, 1
            size_hint_y: None
            height: "60dp"

        # --- Date Display ---
        Label:
            id: date_display
            text: "Check confirmed for this date:"
            halign: "center"
            font_size: "20sp"
            color: 0.5, 0.5, 0.5, 1
            size_hint_y: None
            height: "80dp"

        # --- Success Checkmark ---
        Label:
            text: "✓"
            halign: "center"
            color: 0.2, 0.8, 0.2, 1  # Green
            font_size: "80sp"
            font_name: 'DejaVuSans'
            size_hint_y: None
            height: "100dp"

        # --- Continue Button (Keep User Logged In) ---
        Button:
            text: "RETURN TO SELECTION"
            font_size: "24sp"
            size_hint: 0.7, None
            height: "80dp"
            pos_hint: {"center_x": .5}
            background_normal: ''
            background_color: 0.2, 0.6, 0.8, 1  # Blue
            on_release: root.continue_with_user()

        # --- Return Button ---
        Button:
            text: "RETURN TO START"
            font_size: "24sp"
            size_hint: 0.7, None
            height: "80dp"
            pos_hint: {"center_x": .5}
            background_normal: ''
            background_color: 0.9, 0.17, 0.25, 1  # Red
            on_release: root.return_to_menu()

        # --- Cancel Button ---
        Button:
            text: "CANCEL"
            font_size: "20sp"
            size_hint: 0.7, None
            height: "60dp"
            pos_hint: {"center_x": .5}
            background_normal: ''
            background_color: 0.6, 0.6, 0.6, 1  # Grey
            on_release: root.cancel_transaction()

        # --- Spacer ---
        Widget:
            size_hint_y: 0.1
