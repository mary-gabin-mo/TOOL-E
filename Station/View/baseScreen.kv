<BaseScreen>:
    # 1. Global White Background for all screens
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1 # White
        Rectangle:
            pos: self.pos
            size: self.size
    
    # 2. The Master Layout
    FloatLayout:
        # 3. The Logo
        Image:
            source: "assets/images/logo_black.png"
            size_hint_y: 0.07
            pos_hint: {"top": 0.98, "center_x": .28}
            allow_stretch: True
            keep_ratio: True

        # -- Title --
        MDLabel:
            text: "TOOL-E Kiosk"
            size_hint_y: 0.1
            pos_hint: {"top": 0.9, "center_x": .5}
            halign: "center"
            font_style: "H3"
            theme_text_color: "Primary"
            bold: True

        # -- User Info Below Logo --
        UserInfoFooter:
            size_hint_y: None
            height: "105dp"
            pos_hint: {"bottom": 0.05, "center_x": .5, "x": 0}
            size_hint_x: 1
# --- Global button style ---
<AppButton@Button>:
    background_normal: ''
    background_color: 0.2,0.6,0.86,1  # default blue
    color: 1,1,1,1
    font_size: '28sp'
    size_hint: None, None
    height: dp(90)
    width: dp(280)
    canvas.before:
        Color:
            rgba: self.background_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [22, 22, 22, 22]

# Reusable neutral action button style for use across screens.
<ActionButton@AppButton>:
    base_color: 0.90, 0.90, 0.90, 1
    down_color: 0.74, 0.74, 0.74, 1
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    color: 0.35, 0.35, 0.35, 1
    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.16
        RoundedRectangle:
            pos: self.x, self.y - 3
            size: self.size
            radius: [22, 22, 22, 22]

        Color:
            rgba: (0.74, 0.74, 0.74, 1) if self.state == 'down' else (0.90, 0.90, 0.90, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [22, 22, 22, 22]
    canvas.after:
        Color:
            rgba: (0.55, 0.55, 0.55, 1) if self.state == 'down' else (0.68, 0.68, 0.68, 1)
        Line:
            width: 1.4
            rounded_rectangle: (self.x, self.y, self.width, self.height, 22, 22, 22, 22, 120)
