<WelcomeActionButton@AppButton>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    color: 0.35, 0.35, 0.35, 1
    canvas.before:
        # Soft shadow behind button body
        Color:
            rgba: 0, 0, 0, 0.16
        RoundedRectangle:
            pos: self.x, self.y - 3
            size: self.size
            radius: [22, 22, 22, 22]

        # Main fill with pressed-state feedback
        Color:
            rgba: (0.74, 0.74, 0.74, 1) if self.state == 'down' else (0.90, 0.90, 0.90, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [22, 22, 22, 22]
    canvas.after:
        # Border stroke to define edges
        Color:
            rgba: (0.55, 0.55, 0.55, 1) if self.state == 'down' else (0.68, 0.68, 0.68, 1)
        Line:
            width: 1.4
            rounded_rectangle: (self.x, self.y, self.width, self.height, 22, 22, 22, 22, 120)

<WelcomeScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1  # White background
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: "36dp"
        spacing: "20dp"
        pos_hint: {"center_x": .5, "center_y": .5}

        # -- Logo Area Placeholder --
        Widget:
            size_hint_y: 0.07

        # --- Status Container (swaps between Text and Loading) ---
        BoxLayout:
            id: status_container
            orientation: 'vertical'
            size_hint_y: None
            height: "120dp"
            spacing: "14dp"
            pos_hint: {"center_x": .5}

            # STATE A: Normal Text (Default)
            BoxLayout:
                id: instruction_box
                orientation: 'vertical'
                spacing: "100dp"
                opacity: 1  # Visible

                Label:
                    text: "Checkout / Return Tools Here"
                    halign: "center"
                    font_size: "30sp"
                    bold: True
                    color: 0, 0, 0, 1
                    size_hint_y: None
                    height: "100dp"
                    text_size: self.width, None
                    valign: "middle"

                Label:
                    text: "Please TAP your UNICARD to begin"
                    halign: "center"
                    font_size: "38sp"
                    color: 0.5, 0.5, 0.5, 1
                    size_hint_y: None
                    height: "100dp"
                    text_size: self.width, None
                    valign: "middle"

            # STATE B: Loading (Hidden by default)
            BoxLayout:
                id: loading_box
                orientation: 'vertical'
                opacity: 0  # Hidden
                size_hint_y: None
                height: "0dp"  # Collapse height so it doesn't take space
                spacing: "20dp"

                Label:
                    id: loading_spinner
                    text: "..."
                    halign: "center"
                    font_size: "36sp"
                    color: 0.9, 0.17, 0.25, 1  # Red
                    size_hint: None, None
                    size: "60dp", "60dp"
                    pos_hint: {'center_x': .5}

                Label:
                    text: "Verifying User..."
                    halign: "center"
                    font_size: "36sp"
                    color: 0, 0, 0, 1

        # -- Spacer --
        Widget:
            size_hint_y: None
            height: "44dp"

        # -- Footer Buttons --
        BoxLayout:
            id: footer_buttons
            orientation: 'horizontal'
            size_hint_y: None
            height: "118dp"
            spacing: "18dp"

            # -- DEV BUTTON --
            AppButton:
                text: "DEV - ERROR PAGE)"
                font_size: "30sp"
                size_hint: 1, 1
                pos_hint: {"center_x": .5}
                background_color: 0.4, 0.4, 0.4, 1  # Grey
                on_release: root.go_to('user error screen')

            # # -- DEV BUTTON --
            # AppButton:
            #     text: "DEV - SCAN CARD \n(server OFFLINE)"
            #     font_size: "24sp"
            #     size_hint: 1, 1
            #     pos_hint: {"center_x": .5}
            #     background_color: 0.4, 0.4, 0.4, 1  # Grey
            #     on_release: root.go_to('action selection screen')

        # -- Manual Entry Button --
        WelcomeActionButton:
            text: "MANUAL UCID ENTRY"
            font_size: "30sp"
            size_hint: .65, None
            height: "80dp"
            pos_hint: {"center_x": .5}
            on_release: root.go_to('manual entry screen')

        # -- Spacer --
        Widget:
            size_hint_y: 0.04
    
    # -- Quit Button --
    AppButton:
        text: "QUIT"
        font_size: "15sp"
        size_hint: None, None
        size: "70dp", "35dp"
        pos_hint: {"right": 0.985, "top": 0.12} # bottom right
        on_release: root.exit_program()
