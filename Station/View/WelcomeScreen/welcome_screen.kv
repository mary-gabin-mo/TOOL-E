<WelcomeScreen>:
    md_bg_color: 1, 1, 1, 1  # White background

    MDBoxLayout:
        orientation: 'vertical'
        padding: "36dp"
        spacing: "20dp"
        pos_hint: {"center_x": .5, "center_y": .5}

        # -- Logo Area Placeholder --
        Widget:
            size_hint_y: 0.2
            
        # --- Status Container (swaps between Text and Loading) ---
        MDBoxLayout:
            id: status_container
            orientation: 'vertical'
            size_hint_y: None
            height: "220dp"
            spacing: "14dp"
            pos_hint: {"center_x": .5}
            
            # STATE A: Normal Text (Default)
            MDBoxLayout:
                id: instruction_box
                orientation: 'vertical'
                spacing: "50dp"
                opacity: 1  # Visible
                
                MDLabel:
                    text: "Checkout / Return Tools Here"
                    halign: "center"
                    font_style: "H3"
                    bold: True
                    theme_text_color: "Primary"
                    size_hint_y: None
                    height: "100dp"
                    text_size: self.width, None
                    valign: "middle"

                MDLabel:
                    text: "Please TAP your UNICARD to begin"
                    halign: "center"
                    font_style: "H3"
                    theme_text_color: "Secondary"
                    size_hint_y: None
                    height: "100dp"
                    text_size: self.width, None
                    valign: "middle"
                    # pos_hint: {"top": 0.5, "center_x": .5}
                    
            # STATE B: Loading Animation (Hidden by default)
            MDBoxLayout:
                id: loading_box
                orientation: 'vertical'
                opacity: 0  # Hidden
                size_hint_y: None
                height: "0dp" # Collapse height so it doesn't take space
                spacing: "20dp"
                
                MDSpinner: 
                    id: loading_spinner
                    size_hint: None, None
                    size: "60dp", "60dp"
                    pos_hint: {'center_x': .5}
                    active: False # Stop animation by default
                    palette: [ [0.9, 0.17, 0.25, 1] ] # Red
                    
                MDLabel:
                    text: "Verifying User..."
                    halign: "center"
                    font_style: "H3"
                    theme_text_color: "Primary"

        # -- Spacer --
        Widget:
            size_hint_y: None
            height: "44dp"
            
        # -- Footer Buttons --
        MDBoxLayout:
            id: footer_buttons
            orientation: 'horizontal'
            size_hint_y: None
            height: "118dp"
            spacing: "18dp"

            # -- DEV BUTTON --
            AppButton:
                text: "DEV - SCAN CARD \n(server ON)"
                font_size: "24sp"
                size_hint: 1, 1
                pos_hint: {"center_x": .5}
                background_color: 0.4, 0.4, 0.4, 1  # Grey
                # move on to the next page
                on_release: root.submit_ucid()

            # -- DEV BUTTON --
            AppButton:
                text: "DEV - SCAN CARD \n(server OFFLINE)"
                font_size: "24sp"
                size_hint: 1, 1
                pos_hint: {"center_x": .5}
                background_color: 0.4, 0.4, 0.4, 1  # Grey
                # move on to the next page
                on_release: root.go_to('action selection screen')

        # -- Manual Entry Button --
        AppButton:
            text: "MANUAL UCID ENTRY"
            font_size: "28sp"
            size_hint: 1, None
            height: "96dp"
            pos_hint: {"center_x": .5}
            background_color: 0.85, 0.85, 0.85, 1  # Light grey
            color: 0.35, 0.35, 0.35, 1  # Dark grey text
            on_release: root.go_to('manual entry screen')    
        
        # -- Spacer --
        Widget:
            size_hint_y: 0.04
