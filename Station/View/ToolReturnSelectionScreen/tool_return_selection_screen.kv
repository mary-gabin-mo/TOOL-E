<ReturnToolItem>:
    orientation: "horizontal"
    padding: "15dp"
    spacing: "15dp"
    size_hint_y: None
    height: "100dp"
    
    MDBoxLayout:
        orientation: "vertical"
        pos_hint: {"center_y": .5}
        
        MDLabel:
            text: root.text
            theme_text_color: "Primary"
            font_style: "Subtitle1"
            shorten: True
            shorten_from: "right"
            
        MDLabel:
            text: root.secondary_text
            theme_text_color: "Secondary"
            font_style: "Caption"
            shorten: True
            shorten_from: "right"
            
    MDCheckbox:
        id: cb
        size_hint: None, None
        size: "48dp", "48dp"
        pos_hint: {"center_y": .5}
        active: root.is_active
        on_active: root.on_checkbox_hit(self.active)

<ToolReturnSelectionScreen>:
    md_bg_color: 1, 1, 1, 1

    MDBoxLayout:
        orientation: 'vertical'
        padding: "30dp"
        spacing: "20dp"

        # --- Header ---
        MDLabel:
            id: title_label
            text: "Select Tool to Return"
            halign: "center"
            font_style: "H3"
            bold: True
            size_hint_y: None
            height: "80dp"

        # --- Instructions ---
        MDLabel:
            text: "Check the tool(s) you want to return"
            halign: "center"
            theme_text_color: "Secondary"
            font_style: "Subtitle1"
            size_hint_y: None
            height: "60dp"

        # --- Tool List Container ---
        MDCard:
            orientation: "vertical"
            padding: "10dp"
            size_hint_y: 0.6
            radius: [15, 15, 15, 15]
            elevation: 2

            RecycleView:
                id: tool_recycle_view
                viewclass: 'ReturnToolItem'
                RecycleBoxLayout:
                    default_size: None, dp(72)
                    default_size_hint: 1, None
                    size_hint_y: None
                    height: self.minimum_height
                    orientation: 'vertical'

        # --- Empty Message (hidden when list has items) ---
        MDLabel:
            id: empty_message
            text: "No unreturned tools found"
            halign: "center"
            theme_text_color: "Secondary"
            font_style: "H6"
            opacity: 0
            size_hint_y: None
            height: "60dp"

        # --- Spacer ---
        Widget:
            size_hint_y: 0.05

        # --- Continue Button ---
        MDFillRoundFlatButton:
            id: continue_btn
            text: "CONFIRM RETURN"
            font_size: "24sp"
            size_hint: 0.9, None
            height: "80dp"
            pos_hint: {"center_x": .5}
            md_bg_color: 0.2, 0.7, 0.2, 1  # Green
            disabled: True
            on_release: root.confirm_selection()

        # --- Back Button ---
        MDFillRoundFlatButton:
            text: "BACK"
            font_size: "20sp"
            size_hint: 0.9, None
            height: "60dp"
            pos_hint: {"center_x": .5}
            md_bg_color: 0.6, 0.6, 0.6, 1  # Grey
            on_release: root.go_back()

        # --- Spacer ---
        Widget:
            size_hint_y: 0.05
