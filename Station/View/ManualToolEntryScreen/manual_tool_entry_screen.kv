<ManualToolEntryScreen>:
    md_bg_color: 1, 1, 1, 1

    MDBoxLayout:
        orientation: 'vertical'
        padding: "40dp"
        spacing: "30dp"
        pos_hint: {"center_x": .5, "center_y": .5}

        # Logo Area Placeholder
        Widget:
            size_hint_y: 0.2

        MDLabel:
            text: "Enter Tool Name Manually"
            halign: "center"
            font_style: "H4"
            theme_text_color: "Primary"
            size_hint_y: None
            height: self.texture_size[1]

        MDLabel:
            text: "Please type the name of the tool you are borrowing/returning:"
            halign: "center"
            theme_text_color: "Secondary"
            size_hint_y: None
            height: self.texture_size[1]

        AnchorLayout:
            size_hint_y: 0.3
            anchor_x: "center"
            anchor_y: "center"

            MDTextField:
                id: manual_tool_input
                hint_text: "Tool Name"
                mode: "rectangle"
                size_hint_x: 0.7
                font_size: "24sp"
                multiline: False
                on_text_validate: root.confirm_tool_name()

        MDBoxLayout:
            orientation: 'horizontal'
            spacing: "20dp"
            size_hint_y: None
            height: "60dp"
            pos_hint: {"center_x": 0.5}

            MDRaisedButton:
                text: "Back"
                font_size: "18sp"
                size_hint_x: 0.5
                md_bg_color: 0.5, 0.5, 0.5, 1
                on_release: root.go_back()

            MDRaisedButton:
                id: confirm_button
                text: "Confirm"
                font_size: "20sp"
                size_hint_x: 0.5
                md_bg_color: 0.2, 0.6, 0.8, 1
                disabled: True
                on_release: root.confirm_tool_name()

        Widget:
            size_hint_y: 0.3
