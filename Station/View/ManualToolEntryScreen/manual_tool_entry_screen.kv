<ManualToolEntryScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: "40dp", "30dp", "40dp", "140dp"
        spacing: "20dp"
        pos_hint: {"center_x": .5}

        # Logo Area Placeholder
        Widget:
            size_hint_y: 0.15

        Label:
            text: "Enter Tool Name Manually"
            halign: "center"
            valign: "middle"
            text_size: self.size
            font_size: "44sp"
            color: 0.2, 0.2, 0.2, 1
            bold: True
            size_hint_y: None
            height: self.texture_size[1]

        Label:
            text: "Please type the name of the tool you are borrowing/returning:"
            halign: "center"
            valign: "middle"
            text_size: self.size
            color: 0.4, 0.4, 0.4, 1
            size_hint_y: None
            height: self.texture_size[1]

        AnchorLayout:
            size_hint_y: None
            height: "88dp"
            anchor_x: "center"
            anchor_y: "center"

            TextInput:
                id: manual_tool_input
                hint_text: "Tool Name"
                size_hint_x: 0.7
                size_hint_y: None
                height: "64dp"
                font_size: "22sp"
                multiline: False
                foreground_color: 0, 0, 0, 1
                background_color: 1, 1, 1, 1
                cursor_color: 0, 0, 0, 1
                padding: "12dp", "12dp"
                on_text_validate: root.confirm_tool_name()

        Widget:
            size_hint_y: 1

        MDBoxLayout:
            orientation: 'horizontal'
            spacing: "20dp"
            size_hint_y: None
            height: "72dp"
            pos_hint: {"center_x": 0.5}

            AppButton:
                text: "Back"
                font_size: "24sp"
                size_hint_x: 0.5
                base_color: 0.7, 0.7, 0.7, 1
                down_color: 0.6, 0.6, 0.6, 1
                color: 1, 1, 1, 1
                on_release: root.go_back()

            AppButton:
                id: confirm_button
                text: "Submit"
                font_size: "24sp"
                size_hint_x: 0.5
                base_color: 0.2, 0.7, 0.2, 1
                down_color: 0.15, 0.6, 0.15, 1
                color: 1, 1, 1, 1
                disabled: True
                on_release: root.confirm_tool_name()

        Widget:
            size_hint_y: None
            height: "20dp"
