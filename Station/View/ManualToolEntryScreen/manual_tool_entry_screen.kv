<ManualToolEntryScreen>:
    FloatLayout:
        BoxLayout:
            orientation: 'vertical'
            size_hint: 0.92, 0.68
            pos_hint: {"center_x": 0.5, "top": 0.8}
            spacing: "20dp"

            Label:
                text: "Enter Tool Name Manually"
                halign: "center"
                valign: "middle"
                text_size: self.size
                font_size: "44sp"
                color: 0.2, 0.2, 0.2, 1
                bold: True
                size_hint_y: None
                height: self.texture_size[1]

            Label:
                text: "Please type the name of the tool you are borrowing/returning:"
                halign: "center"
                valign: "middle"
                text_size: self.size
                font_size: "28sp"
                color: 0.4, 0.4, 0.4, 1
                size_hint_y: None
                height: "52dp"

            AnchorLayout:
                size_hint_y: None
                height: "92dp"
                anchor_x: "center"
                anchor_y: "center"

                TextInput:
                    id: manual_tool_input
                    hint_text: "Tool Name"
                    size_hint_x: 0.68
                    size_hint_y: None
                    height: "64dp"
                    font_size: "22sp"
                    multiline: False
                    foreground_color: 0, 0, 0, 1
                    background_color: 1, 1, 1, 1
                    cursor_color: 0, 0, 0, 1
                    padding: "12dp", "12dp"
                    on_text_validate: root.confirm_tool_name()

            Widget:

        BoxLayout:
            orientation: 'horizontal'
            spacing: "20dp"
            size_hint: 0.9, None
            height: "74dp"
            pos_hint: {"center_x": 0.5, "y": 0.145}

            AppButton:
                text: "Back"
                font_size: "30sp"
                size_hint_x: 0.5
                base_color: 0.7, 0.7, 0.7, 1
                down_color: 0.6, 0.6, 0.6, 1
                color: 1, 1, 1, 1
                on_release: root.go_back()

            AppButton:
                id: confirm_button
                text: "Submit"
                font_size: "30sp"
                size_hint_x: 0.5
                base_color: 0.2, 0.7, 0.2, 1
                down_color: 0.15, 0.6, 0.15, 1
                color: 1, 1, 1, 1
                disabled: True
                on_release: root.confirm_tool_name()
