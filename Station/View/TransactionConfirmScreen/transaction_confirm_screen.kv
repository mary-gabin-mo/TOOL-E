# Custom BorderedBox: BoxLayout with ButtonBehavior + dynamic border/background color
<BorderedBox>:
    canvas.before:
        Color:
            rgba: self.bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10, 10, 10, 10]
        Color:
            rgba: self.line_color
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, 10, 10, 10, 10, 100)
            width: 2

<TransactionConfirmScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1  # White background
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: "50dp"
        spacing: "40dp"
        pos_hint: {"center_x": .5, "center_y": .5}

        # --- Logo Area Placeholder ---
        Widget:
            size_hint_y: 0.15

        # --- Title ---
        Label:
            text: "Confirm Transaction"
            halign: "center"
            valign: "middle"
            text_size: self.size
            font_size: "44sp"
            bold: True
            size_hint_y: None
            height: '72dp'
            color: 0, 0, 0, 1

        # Central card
        BoxLayout:
            orientation: 'vertical'
            padding: '15dp'
            spacing: '12dp'
            size_hint: 1, .8  # Wider card so purpose buttons can be wider
            pos_hint: {"center_x": .5}
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15, 15, 15, 15]

            # 1. Scanned Items Header
            Label:
                text: "Items to Checkout"
                halign: "center"
                valign: "middle"
                text_size: self.size
                font_size: "30sp"
                color: 0.5, 0.5, 0.5, 1
                size_hint_y: None
                height: "44dp"

            # 2. Scrollable List of Tools
            ScrollView:
                # size_hint_y: 1.0  # Expand list area and push controls lower
                height: "100dp"
                bar_width: '10dp'

                GridLayout:
                    id: tool_list_container
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    padding: 0

            # Purpose Selection Box
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: "4dp", "10dp"
                spacing: "8dp"

                Label:
                    text: "Purpose of Checkout"
                    halign: "center"
                    valign: "middle"
                    text_size: self.size
                    font_size: "28sp"
                    color: 0.5, 0.5, 0.5, 1
                    size_hint_y: None
                    height: "38dp"

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: "52dp"
                    spacing: "15dp"

                    AppButton:
                        id: btn_academic
                        text: "Academic Course"
                        font_size: "24sp"
                        size_hint_x: 0.5
                        background_normal: ''
                        base_color: 0.9, 0.9, 0.9, 1
                        color: 0, 0, 0, 1
                        on_release: root.select_purpose("Academic Course")

                    AppButton:
                        id: btn_personal
                        text: "Personal Project"
                        font_size: "24sp"
                        size_hint_x: 0.5
                        background_normal: ''
                        base_color: 0.9, 0.9, 0.9, 1
                        color: 0, 0, 0, 1
                        on_release: root.select_purpose("Personal Project")

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: "52dp"
                    spacing: "15dp"

                    AppButton:
                        id: btn_team
                        text: "Team"
                        font_size: "24sp"
                        size_hint_x: 0.6
                        background_normal: ''
                        base_color: 0.9, 0.9, 0.9, 1
                        color: 0, 0, 0, 1
                        on_release: root.select_purpose("Team")

                    AppButton:
                        id: btn_research
                        text: "Research"
                        font_size: "24sp"
                        size_hint_x: 0.6
                        background_normal: ''
                        base_color: 0.9, 0.9, 0.9, 1
                        color: 0, 0, 0, 1
                        on_release: root.select_purpose("Research")

                Widget:
                    size_hint_y: None
                    height: "8dp"

                # Fixed-height slot prevents purpose buttons from shifting when input mode changes
                FloatLayout:
                    size_hint_y: None
                    height: "60dp"

                    # Course code input (shown only when Academic Course is selected)
                    BoxLayout:
                        id: course_code_box
                        orientation: 'horizontal'
                        size_hint: 1, 1
                        pos_hint: {"x": 0, "y": 0}
                        opacity: 0
                        disabled: True
                        spacing: "10dp"

                        Label:
                            text: "Course Code:"
                            size_hint_x: 0.35
                            font_size: "18sp"
                            color: 0, 0, 0, 1
                            halign: "right"
                            valign: "middle"
                            text_size: self.size

                        CourseCodeInput:
                            id: course_code_input
                            hint_text: "e.g. ENEL500"
                            font_size: "22sp"
                            multiline: False
                            size_hint_x: 0.65
                            height: "48dp"
                            on_text: root.on_course_code_changed(self.text)

                    # Team name input (shown only when Team is selected)
                    BoxLayout:
                        id: team_name_box
                        orientation: 'horizontal'
                        size_hint: 1, 1
                        pos_hint: {"x": 0, "y": 0}
                        opacity: 0
                        disabled: True
                        spacing: "10dp"

                        Label:
                            text: "Team Name:"
                            size_hint_x: 0.35
                            font_size: "18sp"
                            color: 0, 0, 0, 1
                            halign: "right"
                            valign: "middle"
                            text_size: self.size

                        TextInput:
                            id: team_name_input
                            hint_text: "Enter team name"
                            font_size: "22sp"
                            multiline: False
                            size_hint_x: 0.65
                            height: "48dp"
                            on_text: root.on_team_name_changed(self.text)

            # 3. Required Action: Date Selection Box
            BorderedBox:
                id: date_box
                orientation: 'vertical'
                size_hint_y: None
                height: "82dp"
                bg_color: 0.95, 0.95, 0.95, 1
                line_color: 1, 0, 0, 1  # Initial Red (Changed in Python code)
                on_release: root.open_calendar()

                Label:
                    id: date_label
                    text: "Tap to select Return Date"
                    halign: "center"
                    valign: "center"
                    font_size: "22sp"
                    color: 0.8, 0.2, 0.2, 1  # Red text initially

            # Keep only a tiny fixed gap before the action bar
            Widget:
                size_hint_y: None
                height: "6dp"

        # --- BOTTOM ACTION BAR ---
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '100dp'
            spacing: '20dp'
            padding: '10dp'

            AppButton:
                text: "BACK"
                font_size: "26sp"
                size_hint_x: 0.4
                background_normal: ''
                base_color: 0.6, 0.6, 0.6, 1
                down_color: 0.5, 0.5, 0.5, 1
                color: 1, 1, 1, 1
                on_release: root.go_back('tool confirm screen')

            AppButton:
                id: confirm_finish_btn
                text: "CONFIRM & FINISH"
                font_size: '26sp'
                size_hint_x: 0.6
                disabled: True  # Disabled until date selected
                background_normal: ''
                base_color: 0.2, 0.7, 0.2, 1  # Green
                down_color: 0.15, 0.6, 0.15, 1
                color: 1, 1, 1, 1
                on_release: root.finish_transaction()

        Widget:
            size_hint_y: None
            height: "40dp"

