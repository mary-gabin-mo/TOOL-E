# Custom BorderedBox: BoxLayout with ButtonBehavior + dynamic border/background color
<BorderedBox>:
    canvas.before:
        Color:
            rgba: self.bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10, 10, 10, 10]
        Color:
            rgba: self.line_color
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, 10, 10, 10, 10, 100)
            width: 2

<TransactionConfirmScreen>:
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1  # White background
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: 'vertical'
        padding: "50dp"
        spacing: "40dp"
        pos_hint: {"center_x": .5, "center_y": .5}

        # --- Logo Area Placeholder ---
        Widget:
            size_hint_y: 0.3

        # --- Title ---
        Label:
            text: "Confirm Transaction"
            halign: "center"
            font_size: "30sp"
            bold: True
            size_hint_y: None
            height: '60dp'
            color: 0, 0, 0, 1

        # Central card
        BoxLayout:
            orientation: 'vertical'
            padding: '15dp'
            spacing: '15dp'
            size_hint: .8, .6  # 80% width, fill remaining height
            pos_hint: {"center_x": .5}
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15, 15, 15, 15]

            # 1. Scanned Items Header
            Label:
                text: "Items to Return"
                halign: "center"
                font_size: "20sp"
                color: 0.5, 0.5, 0.5, 1
                size_hint_y: None
                height: "30dp"

            # 2. Scrollable List of Tools
            ScrollView:
                size_hint_y: 0.5  # Take up 50% of the card height
                bar_width: '10dp'

                GridLayout:
                    id: tool_list_container
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    padding: 0

            # Purpose Selection Box
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: 0.25
                padding: "10dp"
                spacing: "5dp"

                Label:
                    text: "Purpose of Checkout"
                    halign: "center"
                    font_size: "16sp"
                    color: 0.5, 0.5, 0.5, 1
                    size_hint_y: None
                    height: "24dp"

                BoxLayout:
                    orientation: 'horizontal'
                    spacing: "15dp"

                    Button:
                        id: btn_academic
                        text: "Academic Course"
                        size_hint_x: 0.5
                        background_normal: ''
                        background_color: 0.9, 0.9, 0.9, 1
                        color: 0, 0, 0, 1
                        on_release: root.select_purpose("Academic Course")

                    Button:
                        id: btn_personal
                        text: "Personal Project"
                        size_hint_x: 0.5
                        background_normal: ''
                        background_color: 0.9, 0.9, 0.9, 1
                        color: 0, 0, 0, 1
                        on_release: root.select_purpose("Personal Project")

            # 3. Required Action: Date Selection Box
            BorderedBox:
                id: date_box
                orientation: 'vertical'
                size_hint_y: 0.2
                bg_color: 0.95, 0.95, 0.95, 1
                line_color: 1, 0, 0, 1  # Initial Red (Changed in Python code)
                on_release: root.open_calendar()

                Label:
                    id: date_label
                    text: "Tap to select Return Date"
                    halign: "center"
                    valign: "center"
                    color: 0.8, 0.2, 0.2, 1  # Red text initially

            # Spacer to push buttons down
            Widget:
                size_hint_y: 0.1

        # --- BOTTOM ACTION BAR ---
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: '200dp'
            spacing: '20dp'
            padding: '10dp'

            Button:
                text: "CANCEL"
                font_size: "20sp"
                size_hint_x: 0.4
                background_normal: ''
                background_color: 0.6, 0.6, 0.6, 1
                on_release: root.cancel_transaction()

            Button:
                id: confirm_finish_btn
                text: "CONFIRM & FINISH"
                font_size: '20sp'
                size_hint_x: 0.6
                disabled: True  # Disabled until date selected
                background_normal: ''
                background_color: 0.2, 0.7, 0.2, 1  # Green
                on_release: root.finish_transaction()

        Widget:
            size_hint_y: None
            height: "44dp"

