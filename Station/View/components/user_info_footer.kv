#:kivy 2.0

<UserInfoFooter>:
    orientation: 'horizontal'
    padding: "40dp", "10dp"
    spacing: "24dp"
    size_hint_y: None
    height: "120dp"
    canvas.before:
        Color:
            rgba: 0.95, 0.95, 0.95, 1  # Light gray background
        Rectangle:
            pos: self.pos
            size: self.size
    
    # Left: User Info
    BoxLayout:
        orientation: 'vertical'
        spacing: "-5dp"
        size_hint_x: 0.7
        
        Label:
            text: root.user_name
            font_size: "26sp"
            bold: True
            color: 0.2, 0.2, 0.2, 1
            halign: "left"
            valign: "middle"
            text_size: self.size
            size_hint_y: None
            height: "45dp"
            
        Label:
            text: (f"{int(root.user_ucid):08d}" if root.user_ucid != 0 else "--") + " | " + root.user_email
            font_size: "26sp"
            color: 0.4, 0.4, 0.4, 1
            halign: "left"
            valign: "middle"
            text_size: self.size
            size_hint_y: None
            height: "45dp"
    
    # Right: Transaction Type Badge
    Label:
        text: root.transaction_type
        font_size: "26sp"
        bold: True
        color: root.transaction_color
        size_hint_x: 0.3
        padding: "18dp"
        halign: "right"
        valign: "middle"
        text_size: self.size
