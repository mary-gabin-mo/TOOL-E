#:kivy 2.0

<UserInfoFooter>:
    orientation: 'horizontal'
    padding: "40dp", "10dp"
    spacing: "24dp"
    size_hint_y: None
    height: "120dp"
    md_bg_color: 0.95, 0.95, 0.95, 1  # Light gray background
    
    # Left: User Info
    MDBoxLayout:
        orientation: 'vertical'
        spacing: "-5dp"
        size_hint_x: 0.7
        
        MDLabel:
            text: root.user_name
            font_style: "H6"
            font_size: "26sp"
            bold: True
            theme_text_color: "Primary"
            size_hint_y: None
            # height: "40dp"
            
        MDLabel:
            text: f"{int(root.user_ucid):08d}" if root.user_ucid != 0 else "--" + " | " + root.user_email
            font_style: "Subtitle1"
            font_size: "26sp"
            theme_text_color: "Secondary"
            size_hint_y: None
            # height: "34dp"
    
    # Right: Transaction Type Badge
    MDLabel:
        text: root.transaction_type
        font_style: "Subtitle1"
        font_size: "26sp"
        bold: True
        theme_text_color: "Custom"
        text_color: root.transaction_color
        size_hint_x: 0.3
        padding: "18dp"
        halign: "right"
